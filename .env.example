# Postgres
DATABASE_URI=postgres://payload:payload@localhost:5432/justaudit
POSTGRES_PASSWORD=payload

# Payload - generate a long random string, e.g. `openssl rand -base64 32`
PAYLOAD_SECRET=changeme-generate-a-long-random-string

# Public site URL (used for CORS/CSRF and absolute links)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
